# Performance OS env template
# Copy this file to .env.local (or set the vars in Vercel for production).
# See docs/deploy.md for the production deployment recipe.

# --- Web app (public) ---
# Production: the Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=
# Production: Supabase publishable (anon) key. The newer "publishable" naming
# is preferred; the legacy NEXT_PUBLIC_SUPABASE_ANON_KEY alias is also read by
# lib/env.ts.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Production: the canonical HTTPS app URL (e.g. https://app.performanceos.com).
# Used to build absolute callback URLs (Oura, Apple Health push).
NEXT_PUBLIC_APP_URL=

# --- Server-side (do not expose to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=
# Postgres POOLER CONNECTION STRING — must be a postgresql:// URL, NOT the
# REST endpoint. Get it from Supabase Dashboard -> Project Settings ->
# Database -> Connection string -> "Session" mode. Shape:
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# The username is postgres.<project-ref> (the live project ref is
# rwdzoorymkkjnxhexwkz). From WSL prefer the pooler over the direct DB URL
# (CLAUDE.md pitfall #5).
# NOTE: do NOT paste the REST URL (https://<ref>.supabase.co/rest/v1/) here.
# The app talks to Supabase over REST via supabase-js and never reads this
# var; only the direct-pg scripts (apps/web/scripts/) need a real
# postgresql:// string to connect.
DATABASE_URL=

# --- Oura OAuth ---
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
# Optional: only set if you need to override the redirect URI; otherwise the
# app derives it from NEXT_PUBLIC_APP_URL.
OURA_REDIRECT_URI=

# --- Strava OAuth ---
# Create a 'My API Application' at https://www.strava.com/settings/api with
# Authorization Callback Domain set to your production host (no scheme/path).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Random opaque string used to verify Strava's subscription challenge against
# /api/webhooks/strava. Generate with `openssl rand -hex 32` or any UUID;
# use the same value when registering the subscription.
STRAVA_WEBHOOK_VERIFY_TOKEN=

# --- Apple Health push (iPhone Shortcut / iOS client) ---
# Dedicated secret used to sign the per-user push URL. Required in production.
# In local dev, lib/apple-health/automation.ts falls back to
# SUPABASE_SERVICE_ROLE_KEY when this is unset.
APPLE_HEALTH_PUSH_SECRET=
# Optional bucket name for staging raw export uploads.
APPLE_HEALTH_IMPORT_BUCKET=

# --- Scheduled jobs (Vercel Cron) ---
# Shared secret guarding the cron endpoints (e.g. /api/cron/sync-oura, the
# daily Oura recovery sync defined in vercel.json). Vercel automatically sends
# `Authorization: Bearer ${CRON_SECRET}` on cron invocations when this is set;
# the routes fail closed if it's missing. Generate with `openssl rand -hex 32`.
CRON_SECRET=

# --- Optional LLM coach (deterministic fallback when missing) ---
# AI_COACH_API_KEY=
# AI_COACH_MODEL=            # default/cheap model for all surfaces, e.g. gpt-4o-mini
# AI_COACH_BASE_URL=
# Optional cost controls (see lib/agents/llm-model.ts):
# AI_COACH_MODEL_HEAVY=      # higher-tier model used only for heavy surfaces
#                            # (vision lab extraction). Falls back to AI_COACH_MODEL when unset.
# AI_COACH_MAX_TOOL_ITERATIONS=5   # hard cap on tool-loop round-trips per message (default 5)

# --- Misc ---
# Reserved for future research/insights tooling.
OPENAI_API_KEY=
