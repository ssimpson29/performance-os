# Performance OS env template
# Copy this file to .env.local (or set the vars in Vercel for production).
# See docs/deploy.md for the production deployment recipe.

# --- Web app (public) ---
# Production: the Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=
# Production: Supabase publishable (anon) key. The newer "publishable" naming
# is preferred; the legacy NEXT_PUBLIC_SUPABASE_ANON_KEY alias is also read by
# lib/env.ts.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Production: the canonical HTTPS app URL (e.g. https://app.performanceos.com).
# Used to build absolute callback URLs (Oura, Apple Health push).
NEXT_PUBLIC_APP_URL=

# --- Server-side (do not expose to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=
# Postgres pooler URL. From WSL, prefer the pooler over the direct DB URL
# (CLAUDE.md pitfall #5).
DATABASE_URL=

# --- Oura OAuth ---
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
# Optional: only set if you need to override the redirect URI; otherwise the
# app derives it from NEXT_PUBLIC_APP_URL.
OURA_REDIRECT_URI=

# --- Apple Health push (iPhone Shortcut / iOS client) ---
# Dedicated secret used to sign the per-user push URL. Required in production.
# In local dev, lib/apple-health/automation.ts falls back to
# SUPABASE_SERVICE_ROLE_KEY when this is unset.
APPLE_HEALTH_PUSH_SECRET=
# Optional bucket name for staging raw export uploads.
APPLE_HEALTH_IMPORT_BUCKET=

# --- Optional LLM coach (deterministic fallback when missing) ---
# AI_COACH_API_KEY=
# AI_COACH_MODEL=
# AI_COACH_BASE_URL=

# --- Misc ---
# Reserved for future research/insights tooling.
OPENAI_API_KEY=
