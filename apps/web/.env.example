# Web-app-scoped env template. Mirrors the root .env.example for the vars the
# Next.js app reads. See docs/deploy.md for the production deployment recipe.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=

SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# Strava OAuth — create app at https://www.strava.com/settings/api.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Dedicated secret for signing Apple Health push URLs. Falls back to
# SUPABASE_SERVICE_ROLE_KEY for local dev (see lib/apple-health/automation.ts).
APPLE_HEALTH_PUSH_SECRET=
